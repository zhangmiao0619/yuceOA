# ==========================================
# OA 系统 NAS 部署环境变量配置
# ==========================================

# ---------------------------------------------------
# 1. 数据库配置（必填）
# ---------------------------------------------------
# 数据库密码 - 请修改为强密码！
DB_PASSWORD=ChangeThisStrongPassword123

# ---------------------------------------------------
# 2. 安全配置（必填）
# ---------------------------------------------------
# JWT 密钥 - 用于用户认证，请生成随机字符串
# 生成命令: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-here

# ---------------------------------------------------
# 3. 网络配置（必填）
# ---------------------------------------------------
# 前端访问地址 - 改为你的 NAS IP 或域名
# 示例: http://192.168.1.100 或 https://oa.yourdomain.com
FRONTEND_URL=http://localhost

# HTTP 访问端口（如果 80 被占用，改为 8080 等）
HTTP_PORT=80

# 后端 API 端口（一般不需要修改）
BACKEND_PORT=3000

# 数据库端口（如果 5432 被占用，可修改）
DB_PORT=5432

# ---------------------------------------------------
# 4. NAS 数据存储路径（必填）
# ---------------------------------------------------
# 根据你的 NAS 类型修改路径：
# 群晖: /volume1/docker/oa-system/data
# 威联通: /share/Container/oa-system/data
# TrueNAS: /mnt/tank/apps/oa-system/data
# Unraid: /mnt/user/appdata/oa-system/data
# 通用 Linux: /opt/oa-system/data
NAS_DATA_PATH=./data

# ---------------------------------------------------
# 5. 企业微信集成（可选）
# ---------------------------------------------------
# 如需使用企业微信功能，填写以下配置
WECHAT_CORP_ID=
WECHAT_SECRET=

# ---------------------------------------------------
# 6. 高级配置（可选，一般不需要修改）
# ---------------------------------------------------
# 时区设置
TZ=Asia/Shanghai

# 日志级别
LOG_LEVEL=info
